{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "permission": "allow",
  "default_agent": "build",
  "agent": {
    "general": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "max"
    },
    "explore": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "max"
    }
  },
  "provider": {
    "alibaba": {
      "name": "Alibaba",
      "options": {
        "baseURL": "https://token-plan.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1",
        "apiKey": "{env:ALIBABA_API_KEY}"
      }
    }
  },
  "mcp": {
    // Git
    "github": {
      "enabled": true,
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_API_KEY}"
      }
    },
    "gitkraken": {
      "enabled": true,
      "type": "local",
      "command": [
        "gk",
        "mcp"
      ]
    },
    // Context
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "Authorization": "Bearer {env:CONTEXT7_API_KEY}"
      }
    },
    "firecrawl": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.firecrawl.dev/{env:FIRECRAWL_API_KEY}/v2/mcp"
    },
    // Automation
    "playwright": {
      "enabled": true,
      "type": "local",
      "command": [
        "bunx",
        "--bun",
        "@playwright/mcp@latest"
      ]
    },
    "browserbase": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.browserbase.com/mcp?browserbaseApiKey={env:BROWSERBASE_API_KEY}"
    },
    // Services
    "cloudflare": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.cloudflare.com/mcp",
      "headers": {
        "Authorization": "Bearer {env:CLOUDFLARE_API_KEY}"
      }
    },
    "aws": {
      "enabled": true,
      "type": "local",
      "command": [
        "uvx",
        "mcp-proxy-for-aws@latest",
        "https://aws-mcp.us-east-1.api.aws/mcp",
        "--metadata",
        "AWS_REGION=ap-southeast-1"
      ]
    },
    "stitch": {
      "enabled": true,
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp",
      "headers": {
        "X-Goog-Api-Key": "{env:STITCH_API_KEY}"
      }
    },
    "neon": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.neon.tech/mcp",
      "headers": {
        "Authorization": "Bearer {env:NEON_API_KEY}"
      }
    },
    "roboflow": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.roboflow.com/mcp",
      "headers": {
        "x-api-key": "{env:ROBOFLOW_API_KEY}",
        "Accept": "application/json, text/event-stream"
      }
    },
    "sentry": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp"
    },
    "figma": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.figma.com/mcp"
    },
    "clerk": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.clerk.com/mcp"
    },
    "openrouter": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.openrouter.ai/mcp"
    }
  },
  "references": {
    "home": "dentolos19/dentolos19",
    "website": "dentolos19/denizen"
  },
  "plugin": [
    "opencode-notify",
    "opencode-vibeguard"
  ],
  "instructions": [
    "instructions/general.md",
    "instructions/web.md",
    "instructions/python.md"
  ]
}
