{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "permission": "allow",
  "default_agent": "master",
  "mcp": {
    "context7": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "Authorization": "Bearer ${env:CONTEXT7_API_KEY}"
      }
    },
    "firecrawl": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.firecrawl.dev/${env:FIRECRAWL_API_KEY}/v2/mcp"
    }
  },
  "plugin": ["opencode-vibeguard", "opencode-pty"],
  "instructions": ["instructions/general.md", "instructions/web.md", "instructions/python.md"]
}
